{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window (logs, OS info, opener, store, dialog).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "core:app:default",
    "core:path:default",
    "core:webview:default",
    "opener:default",
    "store:default",
    "dialog:default",
    "os:default",
    "log:default"
  ]
}
